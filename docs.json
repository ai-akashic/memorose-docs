              "architecture/memory-hierarchy",
              "architecture/memory-scopes",
              "architecture/storage-engines",
              "architecture/forgetting-strategies"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/basic-operations",
              "guides/hybrid-search",
              "guides/tasks-and-goals",
              "guides/organization-knowledge",
              "guides/knowledge-graph",
              "guides/dashboard",
              "guides/distributed-deployment",
              "guides/multimodal-ingest",
              "guides/benchmarks"
            ]
          },
          {
            "group": "SDKs",
            "pages": [
              "sdks/overview",
              "sdks/python",
              "sdks/node",
              "sdks/java",
              "sdks/go"
            ]
          }
        ]
